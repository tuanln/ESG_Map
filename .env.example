# ESG_Map Environment Variables

# AQICN Air Quality Token (free: https://aqicn.org/data-platform/token/)
AQICN_TOKEN=

# OpenWeatherMap API Key (free: https://openweathermap.org/api)
OPENWEATHER_API_KEY=

# MapTiler Key for map tiles (free: https://www.maptiler.com/)
NEXT_PUBLIC_MAPTILER_KEY=

# NASA FIRMS API Key (free: https://firms.modaps.eosdis.nasa.gov)
NASA_FIRMS_KEY=

# Google AI Studio / Gemini API Key (for AI summaries)
# Get free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# (Optional) ACLED API for live conflict data
# Register at: https://acleddata.com/register/
ACLED_API_KEY=
ACLED_EMAIL=
